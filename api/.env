PORT=5000
SESSION_SECRET=your_session_secret_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h
ENCRYPTION_SECRET=your_32_char_encryption_secret_here
BACKEND_URL=http://localhost:5000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK=http://localhost:5000/auth/google/callback

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_CALLBACK=http://localhost:5000/auth/facebook/callback

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK=http://localhost:5000/auth/linkedin/callback

# Twitter OAuth
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
TWITTER_CALLBACK=http://localhost:5000/auth/twitter/callback

# LDAP / Active Directory
LDAP_URL=ldap://your-ldap-server:389
LDAP_BIND_DN=cn=readonly,dc=example,dc=com
LDAP_BIND_CREDENTIALS=your_readonly_password
LDAP_SEARCH_BASE=dc=example,dc=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# Frontend
FRONTEND_URL=http://localhost:5174

# Environment
NODE_ENV=development
TZ=Asia/Kolkata

# Database
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PWD=your_database_password
DB_PORT=5432
DB_HOST=localhost

JWT_COOKIE_EXPIRES_IN=1
TIMEOUT=1800

# LDAP Test
LDAP_URL=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_PASSWORD=your_admin_password
